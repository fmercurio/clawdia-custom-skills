# Environment variables for Discord Voice Meeting Transcription
#
# Copy this file to .env (or export these variables in your process manager)
# before running the standalone meeting_bot.py reference implementation.
# Never commit real tokens or API keys.
# Keep .env private: chmod 600 .env

# Required: Discord bot token from the Discord Developer Portal.
# The bot must be invited to your server with permission to view channels,
# connect/speak in voice channels as needed, and read message content if using
# text/prefix commands.
DISCORD_BOT_TOKEN=replace_with_your_discord_bot_token

# Required when stt.provider is "groq" or "auto": Groq API key used for hosted
# Whisper-compatible speech-to-text transcription.
GROQ_API_KEY=replace_with_your_groq_api_key

# Required when LLM summary generation is enabled for approved remote providers
# or local endpoints. Custom remote providers must use a provider-specific env
# var named by config.yaml llm.api_key_env, not the generic LLM_API_KEY.
LLM_API_KEY=replace_with_your_llm_api_key

# Optional: override the OpenAI-compatible LLM base URL without editing config.
# Custom remote URLs are denied by default. To intentionally use one, set
# LLM_ALLOW_CUSTOM_REMOTE=1 and configure llm.api_key_env with a provider-specific
# env var in config.yaml.
# Examples:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_ALLOW_CUSTOM_REMOTE=0

# Optional: override the summary model without editing config.
# Examples: gpt-4o-mini, llama-3.1-70b-versatile, qwen2.5:14b
LLM_MODEL=gpt-4o-mini
